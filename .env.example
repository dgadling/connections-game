# Copy to .env and fill in values for local development
# Backend reads these via os.environ at import time (fail-closed)

# Discord OAuth app credentials
# Create an app at https://discord.com/developers/applications
# Add redirect: http://localhost:8000/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# OAuth redirect URI (must match Discord app settings)
DISCORD_REDIRECT_URI=http://localhost:8000/auth/discord/callback

# Fernet key for encrypting Discord OAuth tokens at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DISCORD_OAUTH_FERNET_KEY=

# Optional: Discord user ID that gets owner access to all games (for local admin)
SUPERUSER_DISCORD_ID=

# Database URL (SQLite default)
# For local dev, leaving unset uses backend/connections.db
CONNECTIONS_DB=sqlite:///./connections.db
